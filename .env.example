# ------------------------------------------------------------------
# MaggieAI — environment variables
# Copy to .env (not committed) and customize.
# ------------------------------------------------------------------

# --- Postgres (containerized via docker-compose) -------------------
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=maggieai
POSTGRES_USER=maggieai
POSTGRES_PASSWORD=maggieai_dev_only_change_me

# --- Morphology service (CLTK, containerized) ----------------------
MORPHOLOGY_URL=http://localhost:8002

# --- Local MLX inference service (NATIVE macOS, NOT in Docker) -----
# See README §"Native inference" — runs on your host, not in compose.
INFERENCE_LOCAL_URL=http://host.docker.internal:8001
INFERENCE_LOCAL_MODEL=mlx-community/Qwen2.5-14B-Instruct-4bit

# --- Anthropic API (Claude for the critical reasoning-loop nodes) --
ANTHROPIC_API_KEY=sk-ant-...
CLAUDE_MODEL=claude-sonnet-4-6

# --- Embedding model (BGE-M3 multilingual, downloaded from HF on first run)
EMBEDDING_MODEL=BAAI/bge-m3
EMBEDDING_DIM=1024

# --- Logging / debug ----------------------------------------------
LOG_LEVEL=INFO
LANGSMITH_TRACING=false
# LANGSMITH_API_KEY=ls__...
