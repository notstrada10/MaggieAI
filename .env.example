# ------------------------------------------------------------------
# MaggieAI — variabili d'ambiente
# Copia in .env (non committato) e personalizza.
# ------------------------------------------------------------------

# --- Postgres (containerizzato via docker-compose) -----------------
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=maggieai
POSTGRES_USER=maggieai
POSTGRES_PASSWORD=maggieai_dev_only_change_me

# --- Servizio morfologia (CLTK, containerizzato) -------------------
MORPHOLOGY_URL=http://localhost:8002

# --- Servizio inference locale MLX (NATIVO macOS, non in Docker) ---
# Vedi README §"Inference nativa" — questo gira sul tuo host, non in compose.
INFERENCE_LOCAL_URL=http://host.docker.internal:8001
INFERENCE_LOCAL_MODEL=mlx-community/Qwen2.5-14B-Instruct-4bit

# --- Anthropic API (Claude per nodi critici del reasoning loop) ----
ANTHROPIC_API_KEY=sk-ant-...
CLAUDE_MODEL=claude-sonnet-4-6

# --- Embedding model (BGE-M3 multilingue, scarica da HF al primo run)
EMBEDDING_MODEL=BAAI/bge-m3
EMBEDDING_DIM=1024

# --- Logging / debug ----------------------------------------------
LOG_LEVEL=INFO
LANGSMITH_TRACING=false
# LANGSMITH_API_KEY=ls__...
